# ── Local Database (app metadata, settings, history) ─────────
# docker-compose overrides this with the restorex-db container.
# Only set this if running outside Docker.
# LOCAL_DB_URL=postgresql://postgres:postgres@localhost:5432/pg_backup_manager

# ── Remote Server (configured from the dashboard Settings page) ──
# These are optional defaults — you can configure everything from the app UI
# SSH_HOST=192.168.1.100
# SSH_PORT=22
# SSH_USER=root
# SSH_PASSWORD=
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=

# ── Backup Settings ──────────────────────────────────────────
BACKUP_LOCAL_DIR=D:/Backups/PostgreSQL
BACKUP_REMOTE_TMP_DIR=/tmp/pg_backups
RETENTION_DAYS=7

# ── Flask API ────────────────────────────────────────────────
FLASK_PORT=5000
FLASK_SECRET_KEY=change-this-to-a-random-string

# ── JWT Authentication ─────────────────────────────────────────
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=2
