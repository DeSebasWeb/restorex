# ── Local Database (app metadata, settings, history) ─────────
# Connect to your local PostgreSQL container
LOCAL_DB_URL=postgresql://postgres:postgres@host.docker.internal:5432/pg_backup_manager

# ── Remote Server (configured from the dashboard Settings page) ──
# These are optional defaults — you can configure everything from the app UI
# SSH_HOST=192.168.1.100
# SSH_PORT=22
# SSH_USER=root
# SSH_PASSWORD=
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=

# ── Backup Settings ──────────────────────────────────────────
# In Docker this maps to D:\Backups\PostgreSQL via volume mount
BACKUP_LOCAL_DIR=/backups/databases
BACKUP_REMOTE_TMP_DIR=/tmp/pg_backups
RETENTION_DAYS=7

# ── Flask API ────────────────────────────────────────────────
FLASK_PORT=5000
FLASK_SECRET_KEY=change-this-to-a-random-string
